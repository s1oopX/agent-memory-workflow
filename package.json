{
  "name": "agent-memory-workflow",
  "version": "0.1.20",
  "description": "Local-first file protocol for shared agent memory.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "agent-memory-workflow": "bin/agent-memory-workflow.js"
  },
  "files": [
    "bin",
    "tools",
    "templates",
    "README.md",
    "README.en.md",
    "README.zh-CN.md",
    "LOCAL_USAGE_GUIDE.md",
    "LOCAL_USAGE_GUIDE.en.md",
    "LOCAL_USAGE_GUIDE.zh-CN.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "check": "node --check ./bin/agent-memory-workflow.js",
    "verify": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./tools/verify-agent-memory-workflow.ps1 -Root ./templates -TemplateMode",
    "test": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./tools/test-agent-memory-workflow.ps1",
    "pack:dry-run": "npm pack --dry-run",
    "ci": "npm run check && npm run verify && npm test && npm run pack:dry-run"
  },
  "keywords": [
    "agent",
    "memory",
    "codex",
    "local-first",
    "workflow"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s1oopX/agent-memory-workflow.git"
  }
}
